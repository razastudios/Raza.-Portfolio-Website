{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user" },
        "email": { "type": "string", "format": "email", "description": "The email of the user" },
        "displayName": { "type": "string", "description": "The display name of the user" },
        "photoURL": { "type": "string", "format": "uri", "description": "The photo URL of the user" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created" }
      },
      "required": ["uid", "email"]
    },
    "Message": {
      "title": "Message",
      "description": "A message sent by a user",
      "type": "object",
      "properties": {
        "senderId": { "type": "string", "description": "The ID of the sender" },
        "senderName": { "type": "string", "description": "The name of the sender" },
        "senderEmail": { "type": "string", "format": "email", "description": "The email of the sender" },
        "content": { "type": "string", "description": "The content of the message" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent" }
      },
      "required": ["senderId", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of users"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Collection of messages"
    }
  }
}
